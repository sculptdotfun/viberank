# Active database backend. Production uses `supabase`. `convex` exists in the
# tree as a dormant fallback; set this to `supabase` for normal development.
NEXT_PUBLIC_DATABASE_BACKEND=supabase

# Supabase (required when DATABASE_BACKEND=supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-here # Generate with: openssl rand -base64 32

# GitHub OAuth
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# To get GitHub OAuth credentials:
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Fill in:
#    - Application name: viberank (local)
#    - Homepage URL: http://localhost:3001
#    - Authorization callback URL: http://localhost:3001/api/auth/callback/github
# 4. Copy the Client ID and Client Secret

# Convex (only needed if DATABASE_BACKEND=convex; the Convex implementation
# is dormant and not actively maintained — leaving this unset is fine).
# NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_DEPLOYMENT=
# CONVEX_DEPLOY_KEY=
